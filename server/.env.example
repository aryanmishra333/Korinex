# Copy to server/.env and fill in real values (server/.env is gitignored).

# Neon Postgres pooled connection string (Phase 2a)
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Optional
# PORT=3001

# OAuth (Phase 2c) - fill when setting up the OAuth apps
# SESSION_SECRET="a-long-random-string"
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
